---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const novels = await getCollection('novels', entry => !entry.id.startsWith('_'));
const characters = await getCollection('characters', entry => !entry.id.startsWith('_'));
const guoxue = await getCollection('guoxue', entry => !entry.id.startsWith('_'));
const worldview = await getCollection('worldview', entry => !entry.id.startsWith('_'));
const factions = await getCollection('factions', entry => !entry.id.startsWith('_'));

const categories = [
  {
    id: 'novels',
    title: '藏書閣',
    name: '小說連載',
    desc: '閣中存卷，江湖故事，躍然紙上。包含仙俠、武俠長篇創作。',
    count: novels.length,
    unit: '卷存書',
    link: 'novels',
    icon: '📜'
  },
  {
    id: 'characters',
    title: '俠客譜',
    name: '人物誌設定',
    desc: '江湖豪傑，正邪門派，群俠列傳。記載人物生平、功法與關係。',
    count: characters.length,
    unit: '名俠客',
    link: 'characters',
    icon: '⚔️'
  },
  {
    id: 'guoxue',
    title: '研經室',
    name: '國學筆記',
    desc: '幾案研經，讀書札記，修身齊家。涵蓋儒道釋、古典詩詞與史籍。',
    count: guoxue.length,
    unit: '則筆記',
    link: 'guoxue',
    icon: '✍️'
  },
  {
    id: 'worldview',
    title: '風物誌',
    name: '世界觀設定',
    desc: '玄理風物，天地運行，設定奧秘。揭示功法機制、天地劫數與地理。',
    count: worldview.length,
    unit: '則設定',
    link: 'worldview',
    icon: '🗺️'
  },
  {
    id: 'factions',
    title: '群雄會',
    name: '勢力組織',
    desc: '江湖割據，名門暗潮，群雄並起。記載門派起落、勢力爭奪與地盤。',
    count: factions.length,
    unit: '方勢力',
    link: 'factions',
    icon: '🏯'
  }
];
---

<Layout title="後山 | 創作與筆記" description="後山藏書閣，包含小說連載、人物設定、國學筆記、世界觀與勢力組織">
  <div class="shanzhuang-container ink-fade-in">
    <h1 class="page-title">後山</h1>
    <p class="page-subtitle cursive-title">「一盞清茶論江湖，半壁江山寫墨意」</p>
    <div class="mountain-line"></div>

    <!-- 一鍵續讀卡片 (預設隱藏，由 Client-side JS 讀取 localStorage 後動態顯現) -->
    <div id="resume-read-card" class="resume-read-card hidden ink-fade-in">
      <div class="resume-content">
        <span class="resume-tag cursive-title">🔖 續讀</span>
        <div class="resume-details">
          <span class="resume-title"></span>
          <span class="resume-progress"></span>
        </div>
      </div>
      <a href="#" class="resume-btn font-semibold">繼續閱讀 ➔</a>
    </div>

    <div class="scroll-wrapper">
      <div class="scroll-container" id="scroll-container">
        {categories.map(cat => (
          <div class="scroll-card paper-card">
            <div class="card-icon">{cat.icon}</div>
            <h2 class="card-section-title cursive-title">{cat.title}</h2>
            <h3 class="card-name-title">{cat.name}</h3>
            <p class="card-desc">{cat.desc}</p>
            <div class="card-count-badge">
              <span class="count-num">{cat.count}</span> {cat.unit}
            </div>
            <div class="card-footer">
              <a href={`${import.meta.env.BASE_URL}shanzhuang/${cat.link}`} class="read-btn">
                翻閱此閣 →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  // 垂直滾輪轉橫向滾動，防範觸控板衝突，並在邊界釋放垂直滾動
  function initHorizontalScroll() {
    const container = document.getElementById('scroll-container');
    if (container) {
      container.addEventListener('wheel', (e) => {
        if (e.deltaX === 0) {
          const delta = e.deltaY;
          const scrollLeft = container.scrollLeft;
          const maxScrollLeft = container.scrollWidth - container.clientWidth;
          
          const atLeft = scrollLeft <= 0;
          const atRight = scrollLeft >= maxScrollLeft - 1;
          
          if ((delta < 0 && atLeft) || (delta > 0 && atRight)) {
            return;
          }
          
          e.preventDefault();
          container.scrollLeft += delta * 1.2;
        }
      }, { passive: false });
    }
  }

  // 讀取閱讀進度並顯示卡片
  function checkResumeRead() {
    const card = document.getElementById('resume-read-card');
    if (!card) return;

    try {
      const raw = localStorage.getItem('shanzhuang_last_read');
      if (raw) {
        const record = JSON.parse(raw);
        // 進度在 2% 到 95% 之間時，才顯示續讀橫幅（避免已看完的章節佔版面）
        if (record && record.url && record.percent > 0.02 && record.percent < 0.95) {
          const titleSpan = card.querySelector('.resume-title');
          const progressSpan = card.querySelector('.resume-progress');
          const btn = card.querySelector('.resume-btn');
          
          const typeMap = {
            novels: '藏書閣 · 小說',
            characters: '俠客譜 · 人物',
            worldview: '風物誌 · 設定',
            factions: '群雄會 · 組織',
            guoxue: '研經室 · 國學'
          };
          
          const typeText = typeMap[record.type] || '設定';
          const percentText = Math.round(record.percent * 100);
          
          if (titleSpan) titleSpan.innerText = `《${record.title}》`;
          if (progressSpan) progressSpan.innerText = `分類：${typeText} | 已讀進度：${percentText}% | 閱讀時間：${new Date(record.updatedAt).toLocaleDateString('zh-TW')} ${new Date(record.updatedAt).toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' })}`;
          if (btn) btn.href = record.url;
          
          card.classList.remove('hidden');
          return;
        }
      }
    } catch (e) {}
    card.classList.add('hidden');
  }

  function initShanzhuangHome() {
    initHorizontalScroll();
    checkResumeRead();
  }

  document.addEventListener('astro:page-load', initShanzhuangHome);
  initShanzhuangHome();
</script>

<style>
  .shanzhuang-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    position: relative;
  }
  
  .page-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 0.2rem;
  }
  
  .page-subtitle {
    text-align: center;
    color: var(--color-ink-grey);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  /* 橫向滾動容器包裝器，用於定位漸層遮罩 */
  .scroll-wrapper {
    position: relative;
    width: 100%;
    margin-top: 3rem;
  }

  /* 左右水墨漸層淡出遮罩 */
  .scroll-wrapper::before,
  .scroll-wrapper::after {
    content: '';
    position: absolute;
    top: -10px;
    bottom: -10px;
    width: 120px;
    z-index: 10;
    pointer-events: none; /* 穿透點擊，不阻擋下方點擊 */
    transition: var(--transition-smooth);
  }

  .scroll-wrapper::before {
    left: 0;
    background: linear-gradient(90deg, var(--color-paper-bg) 20%, transparent);
  }

  .scroll-wrapper::after {
    right: 0;
    background: linear-gradient(270deg, var(--color-paper-bg) 20%, transparent);
  }

  /* 滾動容器 */
  .scroll-container {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE 10+ */
    padding: 1.5rem 0.5rem;
    scroll-behavior: smooth;
    gap: 2rem;
  }

  .scroll-container::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  /* 滾動卡片：設定完全固定的寬度與高度，防範字體載入抖動與 Snap 跳動 */
  .scroll-card {
    box-sizing: border-box;
    flex: 0 0 320px;
    width: 320px;
    min-width: 320px;
    max-width: 320px;
    height: 420px;
    min-height: 420px;
    max-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    scroll-snap-align: center;
    padding: 2.5rem 2rem;
    border-radius: 6px;
    position: relative;
    overflow: hidden;
  }

  /* 卡片內部設計 */
  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    opacity: 0.8;
    height: 3rem;
  }

  .card-section-title {
    font-size: 1.8rem;
    color: var(--color-mountain-cyan);
    margin-bottom: 0.3rem;
    line-height: 1.2;
    height: 2.2rem;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .card-name-title {
    font-size: 1.1rem;
    color: var(--color-ink-black);
    font-weight: 600;
    margin-bottom: 1.2rem;
    letter-spacing: 0.05em;
    line-height: 1.4;
    height: 1.5rem;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--color-ink-text);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    height: 7.6rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
  }

  .card-count-badge {
    align-self: flex-start;
    font-size: 0.85rem;
    background: rgba(45, 95, 90, 0.06);
    color: var(--color-mountain-cyan);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    border: 1px solid rgba(45, 95, 90, 0.12);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .count-num {
    font-size: 1.1rem;
    font-family: var(--font-cursive);
    color: var(--color-mountain-green);
  }

  .card-footer {
    border-top: 1px dashed var(--color-border);
    padding-top: 1rem;
    margin-top: auto;
  }

  .read-btn {
    font-size: 0.95rem;
    color: var(--color-mountain-cyan);
    font-weight: 600;
    transition: var(--transition-fast);
    display: inline-block;
  }

  .read-btn:hover {
    color: var(--color-mountain-green);
    transform: translateX(6px);
  }

  /* 一鍵續讀卡片水墨風樣式 */
  .resume-read-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(250, 248, 245, 0.95);
    border: 1px solid #d9d2c9;
    border-radius: 4px;
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    box-shadow: 0 4px 12px rgba(44, 37, 32, 0.06);
    border-left: 3px solid #a63f3f; /* 朱泥紅點綴 */
    font-family: 'LXGW WenKai TC', 'Noto Serif TC', serif;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  
  .resume-read-card.hidden {
    display: none !important;
  }
  
  .resume-content {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  
  .resume-tag {
    font-size: 0.95rem;
    color: #a63f3f;
    background: rgba(166, 63, 63, 0.05);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    border: 1px solid rgba(166, 63, 63, 0.15);
    white-space: nowrap;
  }
  
  .resume-details {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  
  .resume-title {
    font-size: 1.05rem;
    font-weight: bold;
    color: #1a1512;
  }
  
  .resume-progress {
    font-size: 0.8rem;
    color: #8c7f73;
  }
  
  .resume-btn {
    font-size: 0.9rem;
    color: #a63f3f;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  
  .resume-btn:hover {
    color: var(--color-mountain-green);
    transform: translateX(4px);
  }

  /* 響應式佈局：當螢幕寬度較小時，允許垂直平鋪，但仍維持良好的美感 */
  @media (max-width: 768px) {
    .resume-read-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      width: 100%;
      box-sizing: border-box;
    }
    
    .resume-btn {
      align-self: flex-end;
    }

    .scroll-wrapper::before,
    .scroll-wrapper::after {
      display: none; /* 行動端不需要漸層遮罩 */
    }

    .scroll-container {
      flex-direction: column;
      overflow-x: visible;
      scroll-snap-type: none;
      gap: 1.5rem;
      padding: 1rem 0;
    }

    .scroll-card {
      flex: 1 1 auto;
      height: auto;
      min-height: 280px;
    }
  }
</style>

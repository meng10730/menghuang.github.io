---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const novels = await getCollection('novels', entry => !entry.id.startsWith('_'));
const characters = await getCollection('characters', entry => !entry.id.startsWith('_'));
const guoxue = await getCollection('guoxue', entry => !entry.id.startsWith('_'));
const worldview = await getCollection('worldview', entry => !entry.id.startsWith('_'));
const factions = await getCollection('factions', entry => !entry.id.startsWith('_'));

const categories = [
  {
    id: 'novels',
    title: '藏書閣',
    name: '小說連載',
    desc: '閣中存卷，江湖故事，躍然紙上。包含仙俠、武俠長篇創作。',
    count: novels.length,
    unit: '卷存書',
    link: 'novels',
    icon: '📜'
  },
  {
    id: 'characters',
    title: '俠客譜',
    name: '人物誌設定',
    desc: '江湖豪傑，正邪門派，群俠列傳。記載人物生平、功法與關係。',
    count: characters.length,
    unit: '名俠客',
    link: 'characters',
    icon: '⚔️'
  },
  {
    id: 'guoxue',
    title: '研經室',
    name: '國學筆記',
    desc: '幾案研經，讀書札記，修身齊家。涵蓋儒道釋、古典詩詞與史籍。',
    count: guoxue.length,
    unit: '則筆記',
    link: 'guoxue',
    icon: '✍️'
  },
  {
    id: 'worldview',
    title: '風物誌',
    name: '世界觀設定',
    desc: '玄理風物，天地運行，設定奧秘。揭示功法機制、天地劫數與地理。',
    count: worldview.length,
    unit: '則設定',
    link: 'worldview',
    icon: '🗺️'
  },
  {
    id: 'factions',
    title: '群雄會',
    name: '勢力組織',
    desc: '江湖割據，名門暗潮，群雄並起。記載門派起落、勢力爭奪與地盤。',
    count: factions.length,
    unit: '方勢力',
    link: 'factions',
    icon: '🏯'
  }
];
---

<Layout title="後山 | 創作與筆記" description="後山藏書閣，包含小說連載、人物設定、國學筆記、世界觀與勢力組織">
  <div class="shanzhuang-container ink-fade-in">
    <h1 class="page-title">後山</h1>
    <p class="page-subtitle cursive-title">「一盞清茶論江湖，半壁江山寫墨意」</p>
    <div class="mountain-line"></div>

    <div class="scroll-wrapper">
      <div class="scroll-container" id="scroll-container">
        {categories.map(cat => (
          <div class="scroll-card paper-card">
            <div class="card-icon">{cat.icon}</div>
            <h2 class="card-section-title cursive-title">{cat.title}</h2>
            <h3 class="card-name-title">{cat.name}</h3>
            <p class="card-desc">{cat.desc}</p>
            <div class="card-count-badge">
              <span class="count-num">{cat.count}</span> {cat.unit}
            </div>
            <div class="card-footer">
              <a href={`${import.meta.env.BASE_URL}shanzhuang/${cat.link}`} class="read-btn">
                翻閱此閣 →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  // 垂直滾輪轉橫向滾動，防範觸控板衝突，並在邊界釋放垂直滾動
  const container = document.getElementById('scroll-container');
  if (container) {
    container.addEventListener('wheel', (e) => {
      // 觸控板左右滑動時 deltaX != 0，此時不接管以避免衝突
      if (e.deltaX === 0) {
        const delta = e.deltaY;
        const scrollLeft = container.scrollLeft;
        const maxScrollLeft = container.scrollWidth - container.clientWidth;
        
        // 判斷是否在最左端且繼續向上滾動，或在最右端且繼續向下滾動
        const atLeft = scrollLeft <= 0;
        const atRight = scrollLeft >= maxScrollLeft - 1; // 1px 容錯
        
        if ((delta < 0 && atLeft) || (delta > 0 && atRight)) {
          // 到達邊界，釋放攔截，不呼叫 preventDefault()，讓瀏覽器垂直滾動
          return;
        }
        
        e.preventDefault();
        container.scrollLeft += delta * 1.2;
      }
    }, { passive: false });
  }
</script>

<style>
  .shanzhuang-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    position: relative;
  }
  
  .page-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 0.2rem;
  }
  
  .page-subtitle {
    text-align: center;
    color: var(--color-ink-grey);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  /* 橫向滾動容器包裝器，用於定位漸層遮罩 */
  .scroll-wrapper {
    position: relative;
    width: 100%;
    margin-top: 3rem;
  }

  /* 左右水墨漸層淡出遮罩 */
  .scroll-wrapper::before,
  .scroll-wrapper::after {
    content: '';
    position: absolute;
    top: -10px;
    bottom: -10px;
    width: 120px;
    z-index: 10;
    pointer-events: none; /* 穿透點擊，不阻擋下方點擊 */
    transition: var(--transition-smooth);
  }

  .scroll-wrapper::before {
    left: 0;
    background: linear-gradient(90deg, var(--color-paper-bg) 20%, transparent);
  }

  .scroll-wrapper::after {
    right: 0;
    background: linear-gradient(270deg, var(--color-paper-bg) 20%, transparent);
  }

  /* 滾動容器 */
  .scroll-container {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE 10+ */
    padding: 1.5rem 0.5rem;
    scroll-behavior: smooth;
    gap: 2rem;
  }

  .scroll-container::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  /* 滾動卡片：設定完全固定的寬度與高度，防範字體載入抖動與 Snap 跳動 */
  .scroll-card {
    box-sizing: border-box;
    flex: 0 0 320px;
    width: 320px;
    min-width: 320px;
    max-width: 320px;
    height: 420px;
    min-height: 420px;
    max-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    scroll-snap-align: center;
    padding: 2.5rem 2rem;
    border-radius: 6px;
    position: relative;
    overflow: hidden;
  }

  /* 卡片內部設計 */
  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    opacity: 0.8;
    height: 3rem;
  }

  .card-section-title {
    font-size: 1.8rem;
    color: var(--color-mountain-cyan);
    margin-bottom: 0.3rem;
    line-height: 1.2;
    height: 2.2rem;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .card-name-title {
    font-size: 1.1rem;
    color: var(--color-ink-black);
    font-weight: 600;
    margin-bottom: 1.2rem;
    letter-spacing: 0.05em;
    line-height: 1.4;
    height: 1.5rem;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--color-ink-text);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    height: 7.6rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
  }

  .card-count-badge {
    align-self: flex-start;
    font-size: 0.85rem;
    background: rgba(45, 95, 90, 0.06);
    color: var(--color-mountain-cyan);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    border: 1px solid rgba(45, 95, 90, 0.12);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .count-num {
    font-size: 1.1rem;
    font-family: var(--font-cursive);
    color: var(--color-mountain-green);
  }

  .card-footer {
    border-top: 1px dashed var(--color-border);
    padding-top: 1rem;
    margin-top: auto;
  }

  .read-btn {
    font-size: 0.95rem;
    color: var(--color-mountain-cyan);
    font-weight: 600;
    transition: var(--transition-fast);
    display: inline-block;
  }

  .read-btn:hover {
    color: var(--color-mountain-green);
    transform: translateX(6px);
  }

  /* 響應式佈局：當螢幕寬度較小時，允許垂直平鋪，但仍維持良好的美感 */
  @media (max-width: 768px) {
    .scroll-wrapper::before,
    .scroll-wrapper::after {
      display: none; /* 行動端不需要漸層遮罩 */
    }

    .scroll-container {
      flex-direction: column;
      overflow-x: visible;
      scroll-snap-type: none;
      gap: 1.5rem;
      padding: 1rem 0;
    }

    .scroll-card {
      flex: 1 1 auto;
      height: auto;
      min-height: 280px;
    }
  }
</style>

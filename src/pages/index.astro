---
import Layout from '../layouts/Layout.astro';
---

<Layout title="半盞清茶，寫意水墨 | 唐門弟子" description="熱愛古典武俠、寫程式與遊戲開發的唐門子弟，在紛擾塵世中尋求一行乾淨的程式碼與一筆寫意的山水。">
  <div class="home-container">
    
    <!-- 頂部書法字標題區 -->
    <section class="hero-section ink-fade-in">
      <h1 class="cursive-title main-heading">寫意水墨</h1>
      <p class="sub-heading">行於江湖，代碼為劍，墨香為魂</p>
      <div class="mountain-line"></div>
    </section>

    <!-- 個人簡介宣紙卡片 -->
    <section class="intro-section ink-fade-in" style="animation-delay: 0.2s;">
      <div class="paper-card profile-card">
        <h2 class="section-title">自序</h2>
        <p class="profile-text">
          在下唐門弟子，浮沉於代碼與武俠的塵世之中。日間以程式語言構築虛擬乾坤，夜半則沉浸於絲竹雅樂，尋一筆水墨意境。
        </p>
        <p class="profile-text">
          此處乃是在下的賽博山莊，以 <strong>Astro</strong> 框架所建。這裡沒有繁雜的廣告與追蹤，唯有一方宣紙、幾滴墨跡，記錄江湖見聞、技術探索，以及修行心得。
        </p>
        
        <div class="skills-showcase">
          <div class="skill-tag">
            <span class="tag-icon">⚡</span>
            <span>代碼乾坤 (Web 開發)</span>
          </div>
          <div class="skill-tag">
            <span class="tag-icon">🎨</span>
            <span>水墨寫意 (前端美學)</span>
          </div>
          <div class="skill-tag">
            <span class="tag-icon">🎵</span>
            <span>絲竹樂音 (古典氛圍)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 快速導覽按鈕區 -->
    <section class="navigation-section ink-fade-in" style="animation-delay: 0.4s;">
      <div class="action-buttons">
        <a href="/blog" class="action-btn primary-btn">
          <span>觀其文 (進入部落格)</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
          </svg>
        </a>
        <a href="https://github.com/samww" target="_blank" rel="noopener noreferrer" class="action-btn secondary-btn">
          <span>探其源 (GitHub)</span>
        </a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-container {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    padding: 1rem 0;
  }

  .hero-section {
    text-align: center;
    padding: 2rem 0 1rem 0;
  }

  .main-heading {
    font-size: 4.5rem;
    color: var(--color-ink-black);
    margin-bottom: 0.5rem;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
  }

  .sub-heading {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-ink-grey);
    letter-spacing: 0.15em;
  }

  .section-title {
    font-family: var(--font-cursive);
    font-size: 2.2rem;
    font-weight: normal;
    color: var(--color-ink-black);
    margin-bottom: 1.5rem;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 60%;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-mountain-green), transparent);
  }

  .profile-card {
    border-left: 4px solid var(--color-mountain-cyan); /* 用青綠線條點綴左邊框 */
  }

  .profile-text {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--color-ink-text);
    margin-bottom: 1.2rem;
    text-align: justify;
  }

  .profile-text strong {
    color: var(--color-mountain-cyan);
    font-weight: 600;
  }

  .skills-showcase {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--color-border);
  }

  .skill-tag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(230, 223, 204, 0.25);
    border: 1px solid rgba(230, 223, 204, 0.5);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    color: var(--color-ink-grey);
    transition: var(--transition-fast);
  }

  .skill-tag:hover {
    background: rgba(45, 95, 90, 0.08);
    border-color: var(--color-mountain-cyan);
    color: var(--color-mountain-cyan);
    transform: translateY(-2px);
  }

  .tag-icon {
    font-size: 1rem;
  }

  /* 導覽按鈕區 */
  .action-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 2rem;
    border-radius: 4px;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.05rem;
    transition: var(--transition-smooth);
  }

  .primary-btn {
    background: var(--color-ink-black);
    color: var(--color-paper-light);
    border: 1px solid var(--color-ink-black);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
  }

  .primary-btn:hover {
    background: var(--color-mountain-cyan);
    border-color: var(--color-mountain-cyan);
    color: var(--color-paper-light);
    box-shadow: 0 6px 20px rgba(45, 95, 90, 0.2);
    transform: translateY(-2px);
  }

  .secondary-btn {
    background: transparent;
    color: var(--color-ink-text);
    border: 1.5px solid var(--color-border);
  }

  .secondary-btn:hover {
    background: rgba(230, 223, 204, 0.2);
    border-color: var(--color-ink-light);
    transform: translateY(-2px);
  }

  /* 響應式微調 */
  @media (max-width: 768px) {
    .main-heading {
      font-size: 3.2rem;
    }
    .sub-heading {
      font-size: 1.05rem;
    }
    .action-buttons {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }
    .action-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

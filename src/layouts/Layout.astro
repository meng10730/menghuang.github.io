---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import InkCanvas from "../components/InkCanvas.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import GlossaryPopover from "../components/GlossaryPopover.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "筆墨涓流，臨淵探賾 | 晚餐的個人網站",
  description = "晚餐終於擁有瘋狂自言自語的機會啦!",
} = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO 優化 -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- 啟用 Astro 的客戶端路由（前身為 ViewTransitions）以達成無縫音樂與動畫 -->
    <ViewTransitions />
  </head>
  <body>
    <!-- 寫意水墨 Canvas 背景 -->
    <InkCanvas />

    <!-- 全站主排版 -->
    <div class="site-wrapper">
      <!-- 新中式導航列 -->
      <header class="site-header ink-fade-in">
        <nav class="nav-container">
          <div class="nav-logo">
            <a href={import.meta.env.BASE_URL} class="cursive-title ink-logo"
              >吃墨水的晚餐</a
            >
          </div>
          <ul class="nav-links">
            <li>
              <a href={import.meta.env.BASE_URL} class="ink-link nav-item"
                >首頁</a
              >
            </li>
            <li>
              <a
                href={`${import.meta.env.BASE_URL}about`}
                class="ink-link nav-item">關於</a
              >
            </li>
            <li>
              <a
                href={`${import.meta.env.BASE_URL}works`}
                class="ink-link nav-item">作品</a
              >
            </li>
            <li>
              <a
                href={`${import.meta.env.BASE_URL}shanzhuang`}
                class="ink-link nav-item">後山</a
              >
            </li>
            <li>
              <a
                href={`${import.meta.env.BASE_URL}blog`}
                class="ink-link nav-item">部落格</a
              >
            </li>
            <li>
              <a
                href={`${import.meta.env.BASE_URL}keystatic`}
                class="ink-link nav-item admin-login-btn"
                id="admin-login-btn"
                data-astro-reload>莊主登入</a
              >
            </li>
            <li id="admin-logout-item" style="display: none;">
              <a
                href="#"
                class="ink-link nav-item admin-logout-btn"
                id="admin-logout-btn">登出</a
              >
            </li>
          </ul>
        </nav>
      </header>

      <script is:inline>
        function checkAdminStatus() {
          const btn = document.getElementById("admin-login-btn");
          const logoutItem = document.getElementById("admin-logout-item");
          if (btn) {
            try {
              // 1. 優先嘗試從 LocalStorage 讀取官方真正的 key: keystatic-cloud-access-token
              let token = localStorage.getItem("keystatic-cloud-access-token");

              // 2. 備用：從 Cookie 讀取 keystatic-github-token 或是 keystatic-cloud-access-token
              if (!token) {
                const cookies = document.cookie.split(";");
                for (let i = 0; i < cookies.length; i++) {
                  const pair = cookies[i].split("=");
                  const name = pair[0].trim();
                  if (
                    name === "keystatic-github-token" ||
                    name === "keystatic-cloud-access-token"
                  ) {
                    token = pair[1] ? pair[1].trim() : null;
                    break;
                  }
                }
              }

              // 3. 備用：舊版的 keystatic-github-token
              if (!token) {
                token = localStorage.getItem("keystatic-github-token");
              }

              // 4. 備用啟發式搜尋 (尋找任何長度大於 10 且包含 keystatic 或 token 關鍵字的 localStorage 項)
              if (!token) {
                for (let i = 0; i < localStorage.length; i++) {
                  const key = localStorage.key(i);
                  if (
                    key &&
                    (key.includes("keystatic") || key.includes("token"))
                  ) {
                    const val = localStorage.getItem(key);
                    if (val && val.length > 10) {
                      token = val;
                      break;
                    }
                  }
                }
              }

              if (token) {
                btn.textContent = "進入後台";
                btn.title = "您已登入 GitHub 管理者帳號";
                if (logoutItem) logoutItem.style.display = "block";
              } else {
                btn.textContent = "莊主登入";
                btn.title = "登入 GitHub 進行文章編輯";
                if (logoutItem) logoutItem.style.display = "none";
              }
            } catch (e) {
              // 防禦沙箱環境限制
            }
          }
        }

        function setupLogout() {
          const logoutBtn = document.getElementById("admin-logout-btn");
          if (logoutBtn) {
            logoutBtn.addEventListener("click", function (e) {
              e.preventDefault();
              try {
                // 1. 清除 localStorage 特定 token 與 state keys
                localStorage.removeItem("keystatic-cloud-access-token");
                localStorage.removeItem("keystatic-cloud-state");
                localStorage.removeItem("keystatic-github-token");

                // 2. 清除 Cookie 狀態 (涵蓋 Path=/ 與 Path=/keystatic)
                document.cookie =
                  "keystatic-github-token=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;";
                document.cookie =
                  "keystatic-github-token=; Path=/keystatic; Expires=Thu, 01 Jan 1970 00:00:01 GMT;";
                document.cookie =
                  "keystatic-cloud-access-token=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;";
                document.cookie =
                  "keystatic-cloud-access-token=; Path=/keystatic; Expires=Thu, 01 Jan 1970 00:00:01 GMT;";

                // 3. 啟發式清理含有 keystatic 關鍵字之本地快取
                for (let i = localStorage.length - 1; i >= 0; i--) {
                  const key = localStorage.key(i);
                  if (
                    key &&
                    (key.includes("keystatic") || key.includes("token"))
                  ) {
                    localStorage.removeItem(key);
                  }
                }

                checkAdminStatus();
                if (window.location.pathname.startsWith("/keystatic")) {
                  window.location.href = "/";
                }
              } catch (err) {}
            });
          }
        }

        function initScrollTracker() {
          const path = window.location.pathname;
          // 比對是否在詳情頁，如 /shanzhuang/novels/tianxia
          const match = path.match(
            /\/shanzhuang\/(novels|characters|worldview|factions|guoxue)\/([^\/]+)\/?$/,
          );
          if (!match) return;

          const type = match[1];
          const slug = decodeURIComponent(match[2]);

          const titleEl = document.querySelector("h1");
          const title = titleEl
            ? titleEl.innerText.trim()
            : document.title.split("|")[0].trim();

          let scrollTimeout;

          function saveProgress() {
            try {
              const docHeight =
                document.documentElement.scrollHeight - window.innerHeight;
              if (docHeight <= 0) return;

              const percent = window.scrollY / docHeight;

              const record = {
                title: title,
                url: path,
                percent: percent,
                type: type,
                slug: slug,
                updatedAt: new Date().toISOString(),
              };
              localStorage.setItem(
                "shanzhuang_last_read",
                JSON.stringify(record),
              );
            } catch (e) {}
          }

          window.addEventListener("scroll", function () {
            if (scrollTimeout) clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(saveProgress, 300);
          });

          window.addEventListener("beforeunload", saveProgress);

          // 滾動回上次閱讀位置 (防非同步圖片載入抖動與二次定位校準)
          try {
            const raw = localStorage.getItem("shanzhuang_last_read");
            if (raw) {
              const record = JSON.parse(raw);
              if (
                record.url === path &&
                record.percent > 0.02 &&
                record.percent < 0.98
              ) {
                const performScroll = () => {
                  const docHeight =
                    document.documentElement.scrollHeight - window.innerHeight;
                  if (docHeight > 0) {
                    window.scrollTo({
                      top: docHeight * record.percent,
                      behavior: "smooth",
                    });

                    // 定位後加載微幅校準：在滾動動畫大致完成後（800ms）再次微調，防止滾動期間排版微幅改變
                    setTimeout(() => {
                      const currentDocHeight =
                        document.documentElement.scrollHeight -
                        window.innerHeight;
                      window.scrollTo({
                        top: currentDocHeight * record.percent,
                        behavior: "auto",
                      });
                    }, 800);
                  }
                };

                // 檢查是否所有圖片都已載入完成
                const images = Array.from(document.images);
                const promises = images.map((img) => {
                  if (img.complete) return Promise.resolve();
                  return new Promise((resolve) => {
                    img.addEventListener("load", resolve);
                    img.addEventListener("error", resolve); // 錯誤也當作載入完畢，避免卡死
                  });
                });

                // 設定最長等待時間 800ms，避免圖片掛掉或載入過久導致卡死
                const timeoutPromise = new Promise((resolve) =>
                  setTimeout(resolve, 800),
                );

                Promise.race([Promise.all(promises), timeoutPromise]).then(
                  () => {
                    // 圖片載入完成（或超時）後再等 100ms 讓瀏覽器重新排版，隨即執行定位
                    setTimeout(performScroll, 100);
                  },
                );
              }
            }
          } catch (e) {}
        }

        // --- 全域古風按鍵音效系統 (Web Audio API) ---
        let audioCtx = null;
        const sfxBuffers = {
          normal: null,
          high: null,
          low: null,
        };

        async function loadSfx(name, url) {
          try {
            const response = await fetch(url);
            const arrayBuffer = await response.arrayBuffer();
            if (audioCtx) {
              sfxBuffers[name] = await audioCtx.decodeAudioData(arrayBuffer);
            }
          } catch (err) {
            // 僅本地偵錯或靜默降級，不影響使用者
          }
        }

        async function initWebAudioSfx() {
          if (audioCtx) return;
          const AudioContextClass =
            window.AudioContext || window.webkitAudioContext;
          if (!AudioContextClass) return;
          audioCtx = new AudioContextClass();

          await Promise.all([
            loadSfx("normal", "/audio/click.wav"),
            loadSfx("high", "/audio/click-high.wav"),
            loadSfx("low", "/audio/click-low.wav"),
          ]);
        }

        function playClickSfx(type) {
          try {
            // 獨立讀取 LocalStorage 開關 (預設啟用)
            if (
              localStorage.getItem("shanzhuang_sfx_click_enabled") === "false"
            )
              return;

            if (!audioCtx) {
              initWebAudioSfx().then(() => triggerBufferPlay(type));
              return;
            }
            if (audioCtx.state === "suspended") {
              audioCtx.resume();
            }
            triggerBufferPlay(type);
          } catch (e) {}
        }

        function triggerBufferPlay(type) {
          const buffer = sfxBuffers[type];
          if (!buffer || !audioCtx) return;
          const source = audioCtx.createBufferSource();
          source.buffer = buffer;

          // 建立增益節點以將音效音量優化放大
          const gainNode = audioCtx.createGain();
          gainNode.gain.setValueAtTime(3.5, audioCtx.currentTime); // 放大 3.5 倍

          // 建立動態壓縮器平滑最大振幅，防範爆音與削波失真
          const compressor = audioCtx.createDynamicsCompressor();
          compressor.threshold.setValueAtTime(-24, audioCtx.currentTime);
          compressor.knee.setValueAtTime(30, audioCtx.currentTime);
          compressor.ratio.setValueAtTime(12, audioCtx.currentTime);
          compressor.attack.setValueAtTime(0.003, audioCtx.currentTime);
          compressor.release.setValueAtTime(0.25, audioCtx.currentTime);

          source.connect(gainNode);
          gainNode.connect(compressor);
          compressor.connect(audioCtx.destination);
          source.start(0);
        }

        // 首次點擊網頁任意位置自動觸發預載入解碼，並自動移除自身
        function initOnFirstClick() {
          initWebAudioSfx();
          document.removeEventListener("click", initOnFirstClick);
        }

        // 具名全域事件代理監聽器，防止 Astro ViewTransitions 跳轉頁面時重複綁定
        function globalClickListener(e) {
          const target = e.target;
          if (!target) return;

          const clickable = target.closest(
            "a, button, .scroll-card, .member-card, .ink-expand-btn",
          );
          if (!clickable) return;

          // 1. 壞連結 / 未登記設定 (LowVoice)
          if (clickable.classList.contains("broken-link")) {
            playClickSfx("low");
            return;
          }

          // 2. 展開 / 收合 / 特殊開關 (HighVoice)
          if (
            clickable.id === "toggle-members-btn" ||
            clickable.id === "music-toggle" ||
            clickable.classList.contains("ink-expand-btn")
          ) {
            playClickSfx("high");
            return;
          }

          // 3. 一般點擊 (Click2)
          playClickSfx("normal");
        }

        function setupGlobalClickSfx() {
          // 每次加載頁面時，先移除舊的監聽器，再重新綁定，徹底防範換頁失效與重疊
          document.removeEventListener("click", globalClickListener);
          document.removeEventListener("click", initOnFirstClick);

          document.addEventListener("click", globalClickListener);
          document.addEventListener("click", initOnFirstClick);
        }

        function initAdminNav() {
          checkAdminStatus();
          setupLogout();
          initScrollTracker();
          setupGlobalClickSfx();
        }

        document.addEventListener("astro:page-load", initAdminNav);
        initAdminNav();
      </script>

      <!-- 主要內容區域 -->
      <main class="site-main">
        <slot />
      </main>

      <!-- 頁尾 -->
      <footer class="site-footer">
        <div class="footer-content">
          <p>© {new Date().getFullYear()} 唐門弟子. 琴音繚繞，水墨乾坤.</p>
        </div>
      </footer>
    </div>

    <!-- 古風背景音樂播放器 -->
    <AudioPlayer />

    <!-- 全站百科懸浮氣泡 -->
    <GlossaryPopover />
  </body>
</html>

<style>
  .site-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 10; /* 保證在 Canvas 之上 */
  }

  .site-header {
    border-bottom: 1px solid rgba(230, 223, 204, 0.5);
    background: rgba(253, 252, 247, 0.4);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.2rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo .ink-logo {
    font-size: 1.8rem;
    color: var(--color-ink-black);
    text-shadow: 0 0 20px rgba(0, 0, 0, 0.03);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2.5rem;
  }

  .nav-item {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-ink-text);
    padding: 0.3rem 0;
  }

  .nav-item:hover {
    color: var(--color-mountain-cyan);
  }

  .admin-login-btn {
    border: 1px solid rgba(92, 92, 92, 0.25);
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    font-size: 0.95rem !important;
    background: rgba(92, 92, 92, 0.02);
    transition: all 0.25s ease;
  }

  .admin-login-btn:hover {
    background: rgba(92, 92, 92, 0.07);
    border-color: var(--color-mountain-cyan);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
  }

  .admin-logout-btn {
    border: 1px solid rgba(180, 50, 50, 0.2);
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    font-size: 0.95rem !important;
    background: rgba(180, 50, 50, 0.01);
    color: rgba(180, 50, 50, 0.8) !important;
    transition: all 0.25s ease;
  }

  .admin-logout-btn:hover {
    background: rgba(180, 50, 50, 0.06);
    border-color: rgba(180, 50, 50, 0.5);
    color: rgba(180, 50, 50, 1) !important;
    box-shadow: 0 2px 8px rgba(180, 50, 50, 0.03);
  }

  .site-main {
    flex: 1;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .site-footer {
    border-top: 1px solid rgba(230, 223, 204, 0.4);
    padding: 2rem;
    text-align: center;
    background: rgba(253, 252, 247, 0.3);
  }

  .footer-content p {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-ink-grey);
    letter-spacing: 0.05em;
  }

  /* 行動端導航優化 */
  @media (max-width: 768px) {
    .nav-container {
      padding: 1rem 1.5rem;
    }
    .site-main {
      padding: 2rem 1.5rem;
    }
  }
</style>

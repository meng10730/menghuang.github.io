---
// AudioPlayer.astro - 古風背景音樂播放器
---

<div class="audio-player-container" id="audio-player-ui">
  <!-- 背景音樂曲目跑馬燈 -->
  <div class="music-marquee-container" id="music-marquee-container">
    <span class="music-note-icon">🎵</span>
    <div class="music-marquee-inner">
      <span class="music-marquee-content" id="music-marquee-content"></span>
    </div>
  </div>

  <!-- 提示文字，懸停時顯示 -->
  <span class="player-tooltip" id="player-tooltip">開啟背景音樂</span>
  
  <!-- 背景音樂控制鈕 -->
  <button class="music-toggle-btn" id="music-toggle" aria-label="切換背景音樂">
    <!-- 水墨音波跳動線條 -->
    <div class="wave-bar"></div>
    <div class="wave-bar"></div>
    <div class="wave-bar"></div>
    <div class="wave-bar"></div>
  </button>

  <!-- 按鍵音效控制鈕 -->
  <button class="sfx-toggle-btn-global" id="sfx-toggle-global" aria-label="切換按鍵音效">
    <span class="sfx-status-icon" id="sfx-status-icon">🔔</span>
  </button>
  
  <!-- 隱藏的 audio 元素，預設 data-astro-transition-persist 以確保跨頁跳轉不中斷 -->
  <audio 
    id="main-bgm" 
    src="https://assets.mixkit.co/music/preview/mixkit-traditional-oriental-cherry-blossoms-1488.mp3" 
    loop 
    preload="none"
    data-astro-transition-persist="main-bgm-player"
  ></audio>
</div>

<!-- 《活俠傳》背景音樂自訂教學 (註解形式，供使用者查閱) -->
<!-- 
  【如何替換為《活俠傳》背景音樂？】
  1. 將您擁有的《活俠傳》音樂檔案（如：唐門日常.mp3 或 聽雨.mp3）命名為 `bgm.mp3`。
  2. 將檔案放入專案的 `public/` 目錄下（建議在 public 下建置 `audio/` 資料夾，放置為 `public/audio/bgm.mp3`）。
  3. 修改上方 <audio> 標籤中的 src 屬性為：
     src="/audio/bgm.mp3" (若有設定 base 路徑，請注意寫法，如："/repo-name/audio/bgm.mp3")。
  4. 重新建置並上傳即可！
-->

<style>
  .audio-player-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    z-index: 999;
  }

  /* 跑馬燈容器 - 自適應寬度，水墨邊框，宣紙底色 */
  .music-marquee-container {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    background: rgba(253, 252, 247, 0.95);
    border: 0px solid var(--color-border);
    padding: 0;
    border-radius: 20px;
    height: 32px;
    font-size: 0.8rem;
    font-family: var(--font-serif);
    color: var(--color-ink-grey);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
    transition: max-width 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.5s ease, padding 0.5s ease, border-width 0.5s ease, margin-right 0.5s ease;
    pointer-events: none;
  }

  .music-marquee-container.visible {
    max-width: 220px; /* 最大展開寬度 */
    opacity: 1;
    padding: 0 0.8rem;
    border: 1.5px solid var(--color-ink-black);
    margin-right: 0.2rem;
    pointer-events: auto;
  }

  /* 漸隱水墨邊緣遮罩 */
  .music-marquee-inner {
    overflow: hidden;
    white-space: nowrap;
    display: flex;
    flex: 1;
    width: max-content;
    mask-image: linear-gradient(to right, transparent, white 8px, white 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, white 8px, white 92%, transparent);
  }

  .music-marquee-content {
    display: inline-block;
    white-space: nowrap;
  }

  /* 8 秒滾動完一輪，僅當確定需要滾動且 visible 時才啟用 */
  .music-marquee-container.visible.should-scroll .music-marquee-content {
    animation: marquee-scroll 8s linear infinite;
  }

  /* 微幅震動的古風音符 */
  .music-note-icon {
    display: inline-block;
    animation: note-bounce 1.5s ease-in-out infinite alternate;
  }

  @keyframes note-bounce {
    0% {
      transform: translateY(0) rotate(-5deg);
    }
    100% {
      transform: translateY(-2px) rotate(5deg);
    }
  }

  @keyframes marquee-scroll {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0); /* 雙生文字平移一半實現無縫循環 */
    }
  }

  .player-tooltip {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-ink-grey);
    background: rgba(253, 252, 247, 0.9);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    opacity: 0;
    transform: translateX(10px);
    transition: var(--transition-smooth);
    pointer-events: none;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
  }

  .audio-player-container:hover .player-tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  /* 控制按鈕，設計成水墨圓章外觀 */
  .music-toggle-btn, .sfx-toggle-btn-global {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(253, 252, 247, 0.85);
    border: 1.5px solid var(--color-ink-black);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: var(--transition-smooth);
  }

  .music-toggle-btn {
    gap: 3px;
    padding: 0 10px;
  }

  .sfx-toggle-btn-global {
    font-size: 1.25rem;
    color: var(--color-ink-black);
  }

  .music-toggle-btn:hover, .sfx-toggle-btn-global:hover {
    background: var(--color-paper-light);
    border-color: var(--color-mountain-cyan);
    transform: scale(1.05);
  }

  /* 停用狀態的按鍵音按鈕，呈灰墨色 */
  .sfx-toggle-btn-global.muted {
    border-color: rgba(92, 92, 92, 0.35);
    color: var(--color-ink-grey);
    background: rgba(240, 240, 240, 0.65);
    box-shadow: none;
  }

  /* 極簡音波跳動線條 */
  .wave-bar {
    width: 3px;
    height: 8px;
    background-color: var(--color-ink-black);
    border-radius: 2px;
    transition: var(--transition-fast);
  }

  /* 播放時的音波跳動動畫 */
  .playing .wave-bar {
    background-color: var(--color-mountain-cyan);
    animation: bounce 1.2s ease-in-out infinite alternate;
  }

  /* 為每個音波條設定不同的動畫延遲，形成起伏感 */
  .playing .wave-bar:nth-child(1) {
    animation-delay: 0.1s;
    height: 18px;
  }
  .playing .wave-bar:nth-child(2) {
    animation-delay: 0.4s;
    height: 24px;
  }
  .playing .wave-bar:nth-child(3) {
    animation-delay: 0.2s;
    height: 20px;
  }
  .playing .wave-bar:nth-child(4) {
    animation-delay: 0.5s;
    height: 14px;
  }

  /* 暫停或未播放時的靜態高度 */
  .music-toggle-btn:not(.playing) .wave-bar {
    height: 4px;
    background-color: var(--color-ink-light);
  }

  @keyframes bounce {
    0% {
      transform: scaleY(0.3);
    }
    100% {
      transform: scaleY(1.1);
    }
  }

  /* 行動端優化：稍微縮小尺寸，直接隱藏跑馬燈，縮小成正在播放圖示 */
  @media (max-width: 768px) {
    .audio-player-container {
      bottom: 1.5rem;
      right: 1.5rem;
    }
    .music-toggle-btn, .sfx-toggle-btn-global {
      width: 40px;
      height: 40px;
    }
    .player-tooltip {
      display: none; /* 行動端隱藏提示字 */
    }
    .music-marquee-container {
      display: none !important; /* 行動端直接隱藏跑馬燈 */
    }
  }
</style>

<script>
  function initAudioPlayer() {
    const audio = document.getElementById('main-bgm') as HTMLAudioElement;
    const musicBtn = document.getElementById('music-toggle');
    const sfxBtn = document.getElementById('sfx-toggle-global');
    const sfxIcon = document.getElementById('sfx-status-icon');
    const tooltip = document.getElementById('player-tooltip');
    
    // 跑馬燈 DOM 節點
    const marqueeContainer = document.getElementById('music-marquee-container');
    const marqueeContent = document.getElementById('music-marquee-content');

    if (!audio || !musicBtn || !sfxBtn) return () => {};

    // 解析並格式化古風歌名
    const getMusicTitle = (src: string) => {
      if (!src) return '未知曲目';
      if (src.includes('traditional-oriental-cherry-blossoms')) {
        return '《櫻花落》- 古風雅樂';
      }
      if (src.includes('bgm.mp3')) {
        return '《唐門雅樂》- 自訂背景音樂';
      }
      try {
        const url = new URL(src, window.location.href);
        const filename = url.pathname.substring(url.pathname.lastIndexOf('/') + 1);
        const nameWithoutExt = filename.replace(/\.[^/.]+$/, "");
        return `《${decodeURIComponent(nameWithoutExt)}》`;
      } catch (e) {
        return '《唐門雅樂》';
      }
    };

    let isToggling = false;

    // 同步背景音樂按鈕的 UI 狀態與跑馬燈狀態（僅由 play/pause 事件驅動）
    let needScroll = false;

    // 同步背景音樂按鈕的 UI 狀態與跑馬燈狀態（僅由 play/pause 事件驅動）
    const updateMusicUI = () => {
      if (audio.paused) {
        musicBtn.classList.remove('playing');
        if (marqueeContainer) {
          marqueeContainer.classList.remove('visible');
          marqueeContainer.classList.remove('should-scroll');
        }
        needScroll = false;
      } else {
        musicBtn.classList.add('playing');
        if (marqueeContainer && marqueeContent) {
          const title = getMusicTitle(audio.src);
          // 先放置單份文字以測量實際寬度
          marqueeContent.textContent = title;
          marqueeContainer.classList.add('visible');
          
          // 重置滾動狀態
          marqueeContainer.classList.remove('should-scroll');
          needScroll = false;
          
          // 延遲測量以防 DOM 未完全展開，當歌名長度超出 130px 時啟用雙生無縫跑馬燈滾動
          setTimeout(() => {
            if (!audio.paused) {
              const singleWidth = marqueeContent.scrollWidth;
              if (singleWidth > 130) {
                needScroll = true;
                marqueeContent.innerHTML = `<span>${title}</span><span style="display:inline-block; width: 3.5rem;"></span><span>${title}</span>`;
                marqueeContainer.classList.add('should-scroll');
              } else {
                needScroll = false;
                marqueeContent.textContent = title;
              }
            }
          }, 80);
        }
      }
    };

    // 瀏覽器標籤頁隱藏時暫停動畫，節能省電
    const handleVisibilityChange = () => {
      if (!marqueeContainer || !marqueeContent) return;
      if (document.hidden) {
        marqueeContainer.classList.remove('should-scroll');
      } else if (!audio.paused && needScroll) {
        marqueeContainer.classList.add('should-scroll');
      }
    };
    // 引入 Busy Lock 避免快速點擊產生的狀態衝突
    const toggleMusic = () => {
      if (isToggling) return;
      isToggling = true;

      if (audio.paused) {
        audio.play()
          .catch((err) => {
            console.log('音樂播放失敗，可能需要更多使用者互動：', err);
          })
          .finally(() => {
            setTimeout(() => { isToggling = false; }, 200);
          });
      } else {
        audio.pause();
        setTimeout(() => { isToggling = false; }, 200);
      }
    };

    musicBtn.addEventListener('click', toggleMusic);
    audio.addEventListener('play', updateMusicUI);
    audio.addEventListener('pause', updateMusicUI);
    document.addEventListener('visibilitychange', handleVisibilityChange);


    // 2. 同步全域按鍵音效的 UI 狀態
    const updateSfxUI = () => {
      const isEnabled = localStorage.getItem('shanzhuang_sfx_click_enabled') !== 'false';
      if (isEnabled) {
        sfxBtn.classList.remove('muted');
        if (sfxIcon) sfxIcon.textContent = '🔔';
      } else {
        sfxBtn.classList.add('muted');
        if (sfxIcon) sfxIcon.textContent = '🔕';
      }
    };

    const toggleSfx = () => {
      const isEnabled = localStorage.getItem('shanzhuang_sfx_click_enabled') !== 'false';
      localStorage.setItem('shanzhuang_sfx_click_enabled', isEnabled ? 'false' : 'true');
      updateSfxUI();
    };

    sfxBtn.addEventListener('click', toggleSfx);

    // 3. 動態更新 Tooltip 提示內容
    const handleMusicTooltip = () => {
      if (tooltip) tooltip.textContent = audio.paused ? '開啟背景音樂' : '關閉背景音樂';
    };
    const handleSfxTooltip = () => {
      const isEnabled = localStorage.getItem('shanzhuang_sfx_click_enabled') !== 'false';
      if (tooltip) tooltip.textContent = isEnabled ? '關閉按鍵音效' : '開啟按鍵音效';
    };

    musicBtn.addEventListener('mouseenter', handleMusicTooltip);
    sfxBtn.addEventListener('mouseenter', handleSfxTooltip);

    // 初始狀態同步
    updateMusicUI();
    updateSfxUI();

    return () => {
      musicBtn.removeEventListener('click', toggleMusic);
      audio.removeEventListener('play', updateMusicUI);
      audio.removeEventListener('pause', updateMusicUI);
      document.removeEventListener('visibilitychange', handleVisibilityChange);
      sfxBtn.removeEventListener('click', toggleSfx);
      musicBtn.removeEventListener('mouseenter', handleMusicTooltip);
      sfxBtn.removeEventListener('mouseenter', handleSfxTooltip);
    };
  }

  let cleanupAudio: (() => void) | null = null;

  // 配合 Astro ViewTransitions
  document.addEventListener('astro:page-load', () => {
    // 每次 Astro 載入新頁面時，持久化的 audio 依然存在，
    // 但新頁面的 button 需要重新綁定事件。
    if (cleanupAudio) cleanupAudio();
    cleanupAudio = initAudioPlayer();
  });

  document.addEventListener('astro:before-preparation', () => {
    if (cleanupAudio) {
      cleanupAudio();
      cleanupAudio = null;
    }
  });
</script>

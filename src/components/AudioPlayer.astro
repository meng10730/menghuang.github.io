---
// AudioPlayer.astro - 古風背景音樂播放器
---

<div class="audio-player-container" id="audio-player-ui">
  <!-- 提示文字，懸停時顯示 -->
  <span class="player-tooltip" id="player-tooltip">開啟背景音樂</span>
  
  <button class="music-toggle-btn" id="music-toggle" aria-label="切換背景音樂">
    <!-- 水墨音波跳動線條 -->
    <div class="wave-bar"></div>
    <div class="wave-bar"></div>
    <div class="wave-bar"></div>
    <div class="wave-bar"></div>
  </button>
  
  <!-- 隱藏的 audio 元素，啟用 data-astro-transition-persist 以確保跨頁跳轉不中斷 -->
  <audio 
    id="main-bgm" 
    src="https://assets.mixkit.co/music/preview/mixkit-traditional-oriental-cherry-blossoms-1488.mp3" 
    loop 
    preload="none"
    data-astro-transition-persist="main-bgm-player"
  ></audio>
</div>

<!-- 《活俠傳》背景音樂自訂教學 (註解形式，供使用者查閱) -->
<!-- 
  【如何替換為《活俠傳》背景音樂？】
  1. 將您擁有的《活俠傳》音樂檔案（如：唐門日常.mp3 或 聽雨.mp3）命名為 `bgm.mp3`。
  2. 將檔案放入專案的 `public/` 目錄下（建議在 public 下建置 `audio/` 資料夾，放置為 `public/audio/bgm.mp3`）。
  3. 修改上方 <audio> 標籤中的 src 屬性為：
     src="/audio/bgm.mp3" (若有設定 base 路徑，請注意寫法，如："/repo-name/audio/bgm.mp3")。
  4. 重新建置並上傳即可！
-->

<style>
  .audio-player-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    z-index: 999;
  }

  .player-tooltip {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--color-ink-grey);
    background: rgba(253, 252, 247, 0.9);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    opacity: 0;
    transform: translateX(10px);
    transition: var(--transition-smooth);
    pointer-events: none;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
  }

  .audio-player-container:hover .player-tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  /* 音樂切換按鈕，設計成水墨圓章外觀 */
  .music-toggle-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(253, 252, 247, 0.85);
    border: 1.5px solid var(--color-ink-black);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 0 10px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: var(--transition-smooth);
  }

  .music-toggle-btn:hover {
    background: var(--color-paper-light);
    border-color: var(--color-mountain-green);
    transform: scale(1.05);
  }

  /* 極簡音波跳動線條 */
  .wave-bar {
    width: 3px;
    height: 8px;
    background-color: var(--color-ink-black);
    border-radius: 2px;
    transition: var(--transition-fast);
  }

  /* 播放時的音波跳動動畫 */
  .playing .wave-bar {
    background-color: var(--color-mountain-cyan);
    animation: bounce 1.2s ease-in-out infinite alternate;
  }

  /* 為每個音波條設定不同的動畫延遲，形成起伏感 */
  .playing .wave-bar:nth-child(1) {
    animation-delay: 0.1s;
    height: 18px;
  }
  .playing .wave-bar:nth-child(2) {
    animation-delay: 0.4s;
    height: 24px;
  }
  .playing .wave-bar:nth-child(3) {
    animation-delay: 0.2s;
    height: 20px;
  }
  .playing .wave-bar:nth-child(4) {
    animation-delay: 0.5s;
    height: 14px;
  }

  /* 暫停或未播放時的靜態高度 */
  .music-toggle-btn:not(.playing) .wave-bar {
    height: 4px;
    background-color: var(--color-ink-light);
  }

  @keyframes bounce {
    0% {
      transform: scaleY(0.3);
    }
    100% {
      transform: scaleY(1.1);
    }
  }

  /* 行動端優化：稍微縮小尺寸，避免阻擋內容 */
  @media (max-width: 768px) {
    .audio-player-container {
      bottom: 1.5rem;
      right: 1.5rem;
    }
    .music-toggle-btn {
      width: 40px;
      height: 40px;
    }
    .player-tooltip {
      display: none; /* 行動端隱藏提示字 */
    }
  }
</style>

<script>
  function initAudioPlayer() {
    const audio = document.getElementById('main-bgm') as HTMLAudioElement;
    const button = document.getElementById('music-toggle');
    const tooltip = document.getElementById('player-tooltip');

    if (!audio || !button) return;

    // 同步按鈕的 UI 狀態與音訊的播放狀態
    const updateButtonUI = () => {
      if (audio.paused) {
        button.classList.remove('playing');
        if (tooltip) tooltip.textContent = '開啟背景音樂';
      } else {
        button.classList.add('playing');
        if (tooltip) tooltip.textContent = '關閉背景音樂';
      }
    };

    // 點擊按鈕切換播放/暫停
    const togglePlay = () => {
      if (audio.paused) {
        // 現代瀏覽器限制：必須由使用者互動觸發 play()
        audio.play().then(updateButtonUI).catch((err) => {
          console.log('音樂播放失敗，可能需要更多使用者互動：', err);
        });
      } else {
        audio.pause();
        updateButtonUI();
      }
    };

    button.addEventListener('click', togglePlay);

    // 當音樂載入、播放或暫停時同步 UI 狀態
    audio.addEventListener('play', updateButtonUI);
    audio.addEventListener('pause', updateButtonUI);

    // 初始狀態同步
    updateButtonUI();

    // 回傳清理函數，但因為 ViewTransitions 設定了 persist，
    // 我們需要確保事件監聽器在頁面跳轉時不重複綁定。
    return () => {
      button.removeEventListener('click', togglePlay);
      audio.removeEventListener('play', updateButtonUI);
      audio.removeEventListener('pause', updateButtonUI);
    };
  }

  let cleanupAudio: (() => void) | null = null;

  // 配合 Astro ViewTransitions
  document.addEventListener('astro:page-load', () => {
    // 每次 Astro 載入新頁面時，持久化的 audio 依然存在，
    // 但新頁面的 button 需要重新綁定事件。
    if (cleanupAudio) cleanupAudio();
    cleanupAudio = initAudioPlayer();
  });

  document.addEventListener('astro:before-preparation', () => {
    if (cleanupAudio) {
      cleanupAudio();
      cleanupAudio = null;
    }
  });
</script>
